datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  januaId   String   @unique
  email     String   @unique
  publicKey String?  // RSA-OAEP Public Key Base64
  
  // Social Battery
  socialBattery Int? @default(100)
  batteryLastUpdate DateTime? @updatedAt

  // Relations
  memberships      GroupMembership[]
  hostedEvents     Event[]          @relation("EventHost")
  wrappedKeys      WrappedKey[]
  assetWrappedKeys AssetWrappedKey[]
  assets           Asset[]          @relation("AssetOwner")
  loanRequests     LoanRequest[]    @relation("Borrower")
  ledgerEntries    LedgerEntry[]
  keyRotationRequests KeyRotationRequest[] @relation("KeyRotationRequests")
}

model Group {
  id                  String               @id @default(uuid())
  name                String
  memberships         GroupMembership[]
  events              Event[]
  assets              Asset[]
  treasuryPools       TreasuryPool[]
  keyRotationRequests KeyRotationRequest[]
}

model GroupMembership {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])
  role      String   @default("MEMBER") // MEMBER, ADMIN

  @@unique([userId, groupId])
}

model Event {
  id               String   @id @default(uuid())
  hostId           String
  host             User     @relation("EventHost", fields: [hostId], references: [id])
  groupId          String?
  group            Group?   @relation(fields: [groupId], references: [id])

  // Busy Broadcast Fields (Unencrypted)
  startTime        DateTime?
  endTime          DateTime?
  minTrustLayer    String    // Layer enum string: INNER_CIRCLE, OUTER_RING, etc.
  broadcastBusy    Boolean   @default(true)
  isPolling        Boolean   @default(false)

  // Encrypted Envelope
  encryptedPayload String?   // AES-GCM encrypted payload (Base64) - contains Title, Desc, final Location
  
  // Relations
  wrappedKeys      WrappedKey[]
  pollOptions      PollOption[]
}

model PollOption {
  id             String   @id @default(uuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id])
  type           String   // "TIME" or "LOCATION"

  // DEPRECATED: plaintext value — only kept for backward compatibility with existing rows.
  // New records must use encryptedValue instead.
  value          String   @default("")

  // AES-GCM encrypted option label (IV prepended, Base64). Encrypted with the event's group symmetric key.
  encryptedValue String?

  votes          Vote[]
}

model Vote {
  id           String     @id @default(uuid())
  pollOptionId String
  pollOption   PollOption @relation(fields: [pollOptionId], references: [id])
  userId       String
  // Relation to User is implicit for now or we can add it if we want to track who voted
}

model WrappedKey {
  id                     String   @id @default(uuid())
  eventId                String
  event                  Event    @relation(fields: [eventId], references: [id])
  userId                 String
  user                   User     @relation(fields: [userId], references: [id])
  encryptedSymmetricKey  String   // Group Symmetric Key encrypted with User's Public Key (Base64)
  createdAt              DateTime @default(now())

  @@unique([eventId, userId])
}

model Asset {
  id               String   @id @default(uuid())
  ownerId          String
  owner            User     @relation("AssetOwner", fields: [ownerId], references: [id])
  groupId          String?
  group            Group?   @relation(fields: [groupId], references: [id])

  // Encrypted Metadata (Name, Description, Photo URL)
  encryptedMetadata String?  // Base64 AES-GCM blob

  status           String    @default("AVAILABLE") // AVAILABLE, LENT, MAINTENANCE
  visibilityLayer  String    // INNER_CIRCLE, OUTER_RING, etc.
  autoApproveLayer String    @default("INNER_CIRCLE") // Determines auto-approval threshold
  requiresHighCapacity Boolean @default(false)

  loanRequests     LoanRequest[]
  wrappedKeys      AssetWrappedKey[]
}

model LoanRequest {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])
  borrowerId String
  borrower   User     @relation("Borrower", fields: [borrowerId], references: [id])
  trustDistance String @default("OUTER_RING") // Captured trust layer at time of request
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED, RETURNED
  dueDate    DateTime?
  createdAt  DateTime @default(now())
}

model AssetWrappedKey {
  id                     String   @id @default(uuid())
  assetId                String
  asset                  Asset    @relation(fields: [assetId], references: [id])
  userId                 String
  user                   User     @relation(fields: [userId], references: [id])
  encryptedSymmetricKey  String   // Group Symmetric Key encrypted with User's Public Key (Base64)
  createdAt              DateTime @default(now())

  @@unique([assetId, userId])
}

model TreasuryPool {
  id            String        @id @default(uuid())
  groupId       String
  group         Group         @relation(fields: [groupId], references: [id])
  title         String
  description   String?
  goalAmount    Int           // Amount in cents (e.g. 5000 = $50.00)
  currentAmount Int           @default(0)
  status        String        @default("ACTIVE") // ACTIVE, FUNDED, CANCELLED
  createdAt     DateTime      @default(now())

  ledgerEntries LedgerEntry[]
}

model LedgerEntry {
  id            String        @id @default(uuid())
  poolId        String
  pool          TreasuryPool  @relation(fields: [poolId], references: [id])
  contributorId String
  contributor   User          @relation(fields: [contributorId], references: [id])
  amount        Int           // Amount in cents pledged
  memo          String?       // Optional note from the contributor
  createdAt     DateTime      @default(now())
}

// --- Key Rotation ---

// Signal record created when a group admin initiates a key rotation.
// The requesting client uses it to fetch fresh member public keys and re-wrap
// the group's AES-GCM symmetric key for all current members.
model KeyRotationRequest {
  id                String   @id @default(uuid())
  groupId           String
  group             Group    @relation(fields: [groupId], references: [id])
  requestedByUserId String
  requestedBy       User     @relation("KeyRotationRequests", fields: [requestedByUserId], references: [id])
  createdAt         DateTime @default(now())
}
